{
	"name": "problem-response",
	"version": "1.0.0",
	"description": "RFC 9457 Problem Details for HTTP APIs — framework-agnostic, TypeScript-first error responses",
	"license": "MIT",
	"repository": "mstuart/problem-response",
	"author": {
		"name": "Mark Stuart",
		"email": "mstuart@users.noreply.github.com",
		"url": "https://github.com/mstuart"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./index.js"
		}
	},
	"sideEffects": false,
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"test": "xo && ava && tsd"
	},
	"keywords": [
		"rfc9457",
		"rfc7807",
		"problem",
		"details",
		"http",
		"error",
		"api",
		"rest",
		"response",
		"json"
	],
	"dependencies": {
		"error-with-cause": "^1.0.0"
	},
	"devDependencies": {
		"ava": "^8",
		"tsd": "^0.33",
		"xo": "^2.0"
	},
	"xo": {
		"rules": {
			"@typescript-eslint/naming-convention": "off"
		}
	}
}
